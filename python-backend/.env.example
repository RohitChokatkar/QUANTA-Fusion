# QuantFusion v2.0 — Python Backend Environment Variables
# Copy this to .env and fill in your keys
# NEVER commit real values — use Render's Environment Variables dashboard

# ── Fyers API (BSE/NSE data) ──────────────────────
FYERS_CLIENT_ID=32XR2COMHU-100
FYERS_SECRET_KEY=your_secret_key
FYERS_REDIRECT_URI=https://quanta-fusion.web.app/auth
FYERS_ACCESS_TOKEN=your_token_here
FYERS_PIN=your_pin
FYERS_TOTP_SECRET=your_totp_secret

# ── Admin Endpoint Protection ─────────────────────
ADMIN_SECRET=your_strong_secret_here

# ── NewsAPI (Indian sentiment) ────────────────────
NEWS_API_KEY=your_newsapi_key

# ── Twelve Data (Spot Forex + Fallback) ───────────
TWELVE_DATA_API_KEY=your_key

# ── Alpha Vantage (fundamentals) ──────────────────
ALPHA_VANTAGE_API_KEY=your_key

# ── RBI DBIE API (Repo rate) ──────────────────────
RBI_DBIE_API_KEY=your_key

# ── Firebase ──────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=path/to/serviceAccountKey.json

# ── Server ────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
